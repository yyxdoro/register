# Optional: environment. test keeps the current staging/testing defaults; production removes staging from service domains.
REGISTER_ENV=test

# Required: auth service origin. Defaults by REGISTER_ENV: test=https://auth-staging.tripo3d.ai, production=https://auth.tripo3d.ai
# For production overrides, prefer PRODUCTION_AUTH_BASE_URL so staging .env values do not shadow production defaults.
AUTH_BASE_URL=https://auth-staging.tripo3d.ai

# Optional: email template. {{timestamp}} is replaced with a unique value for each account.
# The script always uses the same inbox with the fixed @otpebox.com suffix.
REGISTER_EMAIL=vast-test{{timestamp}}@otpebox.com

# Optional: register multiple accounts serially and save results.
REGISTER_COUNT=1
ACCOUNTS_FILE=registered-accounts.json

# Optional: print response body snippets on successful steps.
DEBUG=false

# Optional: poll otpebox while the email/code service is still syncing.
CODE_POLL_SECONDS=180
CODE_POLL_INTERVAL_MS=3000
CODE_POLL_ATTEMPTS=60

# Optional: retry with a new unique email if the generated email already exists.
EMAIL_ATTEMPTS=5

# Optional: browser origins used to simulate the captured user flow. Defaults by REGISTER_ENV:
# test: WEB_ORIGIN=https://web-testing.tripo3d.ai, APP_ORIGIN=https://beta.tripo3d.ai
# production: WEB_ORIGIN=https://web.tripo3d.ai, APP_ORIGIN=https://studio.tripo3d.ai
WEB_ORIGIN=https://web-testing.tripo3d.ai
APP_ORIGIN=https://beta.tripo3d.ai

# Optional: base URL for the business API that consumes the tokenized JWT.
# Defaults by REGISTER_ENV: test=https://api-staging.tripo3d.ai, production=https://api.tripo3d.ai
# For production overrides, use PRODUCTION_API_BASE_URL/PRODUCTION_WEB_ORIGIN/PRODUCTION_APP_ORIGIN.
API_BASE_URL=https://api-staging.tripo3d.ai
